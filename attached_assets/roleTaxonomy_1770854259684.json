  "seniorityLevels": {
    "intern": {
      "level": 0,
      "patterns": ["intern", "internship", "co.?op", "apprentice", "trainee"],
      "apolloSeniority": "entry"
    },
    "junior": {
      "level": 1,
      "patterns": ["junior", "entry.?level", "associate", "jr\\.?", "i$", "level 1", "l1"],
      "apolloSeniority": "entry"
    },
    "mid": {
      "level": 2,
      "patterns": ["mid.?level", "intermediate", "ii$", "level 2", "l2", "2$"],
      "apolloSeniority": "senior"
    },
    "senior": {
      "level": 3,
      "patterns": ["senior", "sr\\.?", "iii$", "level 3", "l3", "3$", "lead"],
      "apolloSeniority": "senior"
    },
    "staff": {
      "level": 4,
      "patterns": ["staff", "principal", "iv$", "level 4", "l4", "distinguished"],
      "apolloSeniority": "manager"
    },
    "manager": {
      "level": 5,
      "patterns": ["manager", "team lead", "supervisor", "group lead"],
      "apolloSeniority": "manager"
    },
    "senior_manager": {
      "level": 6,
      "patterns": ["senior manager", "head of", "group manager"],
      "apolloSeniority": "director"
    },
    "director": {
      "level": 7,
      "patterns": ["director", "senior director", "executive director"],
      "apolloSeniority": "director"
    },
    "vp": {
      "level": 8,
      "patterns": ["vp", "vice president", "svp", "senior vice president", "evp"],
      "apolloSeniority": "vp"
    },
    "c_suite": {
      "level": 9,
      "patterns": ["chief", "c-level", "cto", "cfo", "cmo", "coo", "cpo", "cro", "ceo", "founder", "co.?founder", "partner"],
      "apolloSeniority": "c_suite"
    }
  },

